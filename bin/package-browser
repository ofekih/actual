#!/bin/bash -e

ROOT=`dirname $0`

cd "$ROOT/.."

SKIP_TRANSLATIONS=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-translations)
      SKIP_TRANSLATIONS=true
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

if [ "$SKIP_TRANSLATIONS" = false ]; then
  echo "Updating translations..."
  rm -rf packages/desktop-client/locale
  git clone --depth=1 https://github.com/actualbudget/translations packages/desktop-client/locale
  rm -rf packages/desktop-client/locale/.git
  packages/desktop-client/bin/remove-untranslated-languages
fi

lage build:browser --to=@actual-app/web
